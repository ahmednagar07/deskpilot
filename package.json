{
  "name": "deskpilot",
  "version": "0.7.0",
  "description": "Smart desktop management app — organize files, clean storage, find anything instantly",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json -w",
    "dev:renderer": "vite dev src/renderer --port 5173",
    "build": "npm run build:main && npm run build:renderer",
    "copy:sql": "node -e \"const fs=require('fs'),p=require('path');const s='src/main/database/migrations',d='dist/main/database/migrations';fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)));console.log('Copied migrations to '+d)\"",
    "build:main": "tsc -p tsconfig.main.json && npm run copy:sql",
    "build:renderer": "vite build",
    "start": "electron dist/main/index.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --win --mac --linux",
    "generate-icons": "node scripts/generate-icons.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest"
  },
  "keywords": [
    "desktop",
    "file-manager",
    "organizer",
    "electron"
  ],
  "author": "Nagar",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.1.0",
    "zustand": "^5.0.12"
  }
}
